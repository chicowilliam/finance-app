# Copie este arquivo para .env e preencha os valores

# PostgreSQL connection string (Neon, Railway, Supabase, etc.)
# Exemplo Neon: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/finance_app?schema=public"

# Chave secreta para JWT (troque em produção!)
JWT_SECRET="finance-app-dev-secret-change-in-production"

# Origens permitidas no CORS (separadas por vírgula)
# Exemplo: https://finance-app.vercel.app,http://localhost:5173
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# URL base do frontend (usada para links de confirmacao e recuperacao de senha)
APP_BASE_URL="http://localhost:5173"

# Remetente de e-mail
# Em producao use um dominio verificado no Resend, ex: no-reply@seu-dominio.com
EMAIL_FROM="onboarding@resend.dev"

# Chave da API do Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
